{
  "schema_version": 1,
  "scope": "pr238g-canonical-agent-state-registry",
  "description": "Canonical registry of agent and environment state surfaces. It defines which sources are authoritative for repo, workspace, policy, and decision-state reads.",
  "state_groups": {
    "local": [
      {
        "name": "repo_truth",
        "authoritative_source": "terminal",
        "evidence": [
          "git branch --show-current",
          "git status --short --branch",
          "git diff --shortstat",
          "git rev-parse --short HEAD"
        ],
        "consumers": [
          "local-first-repo-truth-agent",
          "local-first-repo-truth-preflight-probe",
          "local-first-env-index-readiness-probe",
          "local-first-agent-decision-evidence-probe",
          "local-first-agent-decision-gate"
        ]
      },
      {
        "name": "workspace_index",
        "authoritative_source": "config/chat_operator/vscode_workspace_context_contract.json",
        "evidence": [
          "chat.useAgentsMdFile",
          "chat.useNestedAgentsMdFiles",
          "venom.workspaceIndexMode",
          "venom.workspaceContextDefault"
        ],
        "consumers": [
          "local-first-workspace-context-probe",
          "local-first-env-index-readiness-probe",
          "local-first-agent-decision-gate"
        ]
      }
    ],
    "remote": [
      {
        "name": "decision_policy",
        "authoritative_source": "config/chat_operator/venom_agent_decision_contract.json",
        "evidence": [
          "decision_policy",
          "repo_context_policy",
          "repo_truth_policy",
          "required_env_commands",
          "required_tools",
          "required_repo_refs",
          "required_index_markers",
          "required_response_fields"
        ],
        "consumers": [
          "local-first-env-index-readiness-probe",
          "local-first-agent-decision-evidence-probe",
          "local-first-agent-decision-gate"
        ]
      },
      {
        "name": "routing_policy",
        "authoritative_source": "config/chat_operator/decision_gate_contract.json",
        "evidence": [
          "operator_model_local_first",
          "utility_model",
          "utility_small_model",
          "main_window_policy",
          "agents_window_policy",
          "remote_agents_policy",
          "repo_truth_policy"
        ],
        "consumers": [
          "local-first-decision-gate",
          "local-first-agent-decision-gate"
        ]
      },
      {
        "name": "operator_tool_profile",
        "authoritative_source": "config/chat_operator/venom_operator_tool_profile.json",
        "evidence": [
          "decision_policy",
          "core_tools",
          "extended_tools",
          "default_repo_probes"
        ],
        "consumers": [
          "local-first-operator-tool-profile-probe",
          "local-first-agent-decision-gate"
        ]
      }
    ],
    "hybrid": [
      {
        "name": "decision_pipeline",
        "authoritative_source": "test-results/237/* + test-results/238g/agent_state_registry_probe.json",
        "evidence": [
          "env_index",
          "policy",
          "decision_evidence",
          "state_registry"
        ],
        "consumers": [
          "local-first-agent-decision-gate"
        ]
      }
    ]
  },
  "notes": [
    "Registry is read-only and should be consumed by probes and gates rather than duplicated in docs.",
    "Local state comes from terminal commands or local contracts; remote state comes from config contracts; hybrid state composes both.",
    "The live snapshot is generated by scripts/dev/238g_agent_state_registry_probe.py and stored in test-results/238g/."
  ]
}
