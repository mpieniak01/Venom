{
  "name": "web-next",
  "version": "1.8.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "predev": "node scripts/prepare-optional-module-node-paths.mjs && node scripts/generate-meta.mjs",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:turbo:debug": "NEXT_TELEMETRY_DISABLED=1 NEXT_DEBUG=true NODE_OPTIONS=--trace-warnings next dev --turbo",
    "prebuild": "node scripts/prepare-optional-module-node-paths.mjs && node scripts/generate-meta.mjs",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-server.mjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0 && printf \"\\033[32m✔ Lint OK\\033[0m\\n\"",
    "test:unit": "node --import tsx --test --test-reporter=dot tests/*.test.ts",
    "test:unit:components": "node --import tsx --import ./tests/component-test-setup.ts --test --test-concurrency=1 --test-reporter=spec tests/*.component.test.tsx",
    "test:unit:coverage": "npx --yes c8@10.1.3 --reporter=lcov --reporter=text --reports-dir coverage node --import tsx --test tests/*.test.ts",
    "test:unit:ci-lite": "npm run test:unit && npm run test:unit:components",
    "codegen:api-types": "npx --yes openapi-typescript@7.10.1 ../openapi/openapi.json -o lib/generated/api-types.d.ts",
    "test:e2e:smoke": "PLAYWRIGHT_REUSE_SERVER=true PLAYWRIGHT_MODE=dev playwright test tests/smoke.spec.ts --workers=1",
    "test:e2e:smoke:academy": "PLAYWRIGHT_REUSE_SERVER=true PLAYWRIGHT_MODE=dev playwright test tests/academy-smoke.spec.ts --workers=1",
    "test:e2e:latency": "PLAYWRIGHT_REUSE_SERVER=true PLAYWRIGHT_MODE=dev playwright test tests/perf/chat-latency.spec.ts --workers=1",
    "test:e2e:functional": "PLAYWRIGHT_REUSE_SERVER=true PLAYWRIGHT_MODE=dev playwright test tests/chat-mode-routing.spec.ts tests/streaming.spec.ts tests/chat-context-icons.spec.ts",
    "test:e2e:preflight": "node scripts/check-e2e-env.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:profile:smoke": "E2E_PROFILE=smoke node scripts/run-e2e.mjs",
    "test:e2e:profile:functional": "E2E_PROFILE=functional node scripts/run-e2e.mjs",
    "test:e2e:profile:full": "E2E_PROFILE=full node scripts/run-e2e.mjs",
    "test:e2e:trend": "node scripts/e2e-trend-report.mjs",
    "test:e2e:quality-gate": "node scripts/e2e-quality-gate.mjs",
    "test:e2e:prod": "npm run build && PLAYWRIGHT_MODE=prod playwright test",
    "test:perf:ci:backend": "PERF_NEXT_REQUIRED=true playwright test --config playwright.perf.config.ts --reporter=json,line",
    "test:perf:summary": "node scripts/perf-latency-summary.mjs",
    "test:dev:turbo:smoke": "node scripts/check-dev-turbo.mjs",
    "test:dev:turbo:smoke:clean": "TURBO_SMOKE_CLEAN_NEXT=1 node scripts/check-dev-turbo.mjs",
    "test:perf": "playwright test --config playwright.perf.config.ts",
    "lint:locales": "tsx scripts/check-locales.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@xyflow/react": "^12.10.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.3.3",
    "eventsource-parser": "^3.0.6",
    "framer-motion": "^12.23.26",
    "katex": "^0.16.27",
    "lucide-react": "^0.561.0",
    "marked": "15.0.12",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.53",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "dagre-d3-es": "7.0.13",
    "marked": "15.0.12"
  }
}
