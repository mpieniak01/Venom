NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_URL_SCHEME_POLICY=auto
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
API_PROXY_TARGET=http://localhost:8000
NEXT_PUBLIC_ENABLE_AUDIO_INTERFACE=false
NEXT_PUBLIC_ENABLE_IOT_STATUS=false
NEXT_PUBLIC_DISABLE_API_POLLING=false
NEXT_PUBLIC_DISABLE_WS_EVENTS=false
NEXT_PUBLIC_FEATURE_BRAND_STUDIO=true
NEXT_PUBLIC_ORB_EFFECT_PROFILE=balanced
NEXT_PUBLIC_VOICE_RENDER_DIAGNOSTIC_MODE=off
NEXT_PUBLIC_VOICE_DEBUG_STEP_MS=3000
NEXT_PUBLIC_VOICE_DEBUG_LOOP=true
NEXT_PUBLIC_VOICE_DEBUG_TRANSCRIPT=Powiedz mi prosze, co to jest kwadrat?
NEXT_PUBLIC_VOICE_DEBUG_RESPONSE=Kwadrat to figura geometryczna z czterema rownymi bokami i czterema katami prostymi.
NEXT_PUBLIC_ORB_RIPPLE=true
NEXT_PUBLIC_ORB_BLOB=true
NEXT_PUBLIC_ORB_GLOW=true
NEXT_PUBLIC_ORB_TRANSITIONS=false
NEXT_PUBLIC_ORB_FREQUENCY_RING=true
NEXT_PUBLIC_ORB_CORE_TEXTURE=false
NEXT_PUBLIC_ORB_PARTICLES=true
NEXT_PUBLIC_ORB_STATE_LABEL=true
NEXT_PUBLIC_ORB_METRICS_BARS=true
NEXT_PUBLIC_ORB_3D=false
NEXT_PUBLIC_ORB_BLOOM=false
NEXT_PUBLIC_ORB_CHROMATIC_ABERRATION=false
NEXT_PUBLIC_ORB_IRIDESCENCE=false
NEXT_PUBLIC_ORB_VOLUMETRIC_LIGHTS=false
